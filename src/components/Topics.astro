---
// Topic Ticker Section - Scrolling blocks from right to left
---

<section id="topics" class="py-12 overflow-hidden border-t border-b border-zinc-200 bg-white relative">
    <div class="flex items-center gap-4 mb-6 px-6">
        <h4 class="text-xs font-bold tracking-widest text-zinc-400 uppercase whitespace-nowrap">TOPICS</h4>
        <div class="h-px bg-zinc-200 flex-1"></div>
    </div>
    
    <div class="topic-ticker-wrapper">
        <div id="topics-track" class="topic-ticker-track">
            <!-- Topics injected by JS -->
        </div>
    </div>
</section>
